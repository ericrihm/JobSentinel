{
  "manifest_version": 3,
  "name": "JobSentinel",
  "version": "0.1.0",
  "description": "AI-powered LinkedIn job scam detection",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.linkedin.com/jobs/*", "http://localhost:8080/*"],
  "action": {"default_popup": "popup.html", "default_title": "JobSentinel"},
  "content_scripts": [{"matches": ["https://www.linkedin.com/jobs/*"], "js": ["content.js"], "run_at": "document_idle"}],
  "background": {"service_worker": "background.js"}
}

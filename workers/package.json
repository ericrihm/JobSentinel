{
  "name": "jobsentinel-worker",
  "version": "1.0.0",
  "description": "JobSentinel job scam analysis API — Cloudflare Workers deployment",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute jobsentinel-db --file=src/schema.sql",
    "db:init:remote": "wrangler d1 execute jobsentinel-db --remote --file=src/schema.sql",
    "logs": "wrangler tail",
    "test": "vitest"
  },
  "devDependencies": {
    "wrangler": "^3.0.0",
    "vitest": "^1.0.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0"
  }
}

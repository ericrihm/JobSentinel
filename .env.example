# Sentinel Environment Variables
# Copy to .env and fill in values

# Optional: API key for authenticating requests to the FastAPI server
# Leave empty for unauthenticated access
SENTINEL_API_KEY=

# Optional: Anthropic API key for Claude AI-powered analysis escalation
ANTHROPIC_API_KEY=

# Optional: SQLite database path (defaults to ./sentinel.db)
SENTINEL_DB_PATH=

# Optional: Google Safe Browsing API key for URL reputation checks
GOOGLE_SAFE_BROWSING_API_KEY=

# Required for CI/CD: Cloudflare API token for worker deployment
# Set as GitHub Actions secret, not in .env
# CLOUDFLARE_API_TOKEN=
